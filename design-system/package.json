{
  "name": "harbor-design-system",
  "version": "0.1.0",
  "description": "Warm, data-forward React design system extracted from the Household Portfolio Tracker.",
  "type": "module",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./harbor.css": "./dist/harbor.css",
    "./tokens.json": "./dist/tokens.json"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "design-system",
    "react",
    "ui",
    "components",
    "dashboard"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  }
}
